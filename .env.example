# Plane Lite Environment Variables
# Copy this file to .env and update the values

# MySQL Configuration
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=plane_lite
MYSQL_USER=plane_user
MYSQL_PASSWORD=plane_password_change_me

# JWT Configuration
# IMPORTANT: Generate a secure secret key (at least 32 characters)
# You can use: openssl rand -base64 32
JWT_SECRET=your-secret-key-at-least-32-characters-long-change-me
JWT_EXPIRATION=604800000

# Application Ports (optional, defaults in docker-compose.yml)
BACKEND_PORT=8080
FRONTEND_PORT=80
